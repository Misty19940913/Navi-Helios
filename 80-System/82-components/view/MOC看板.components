      "enableMarkLine": false,
      "markLineValue": 20,
      "showDataValue": false,
      "valueScaleStartFromZero": true,
      "smoothLine": false,
      "fillArea": false,
      "options": {},
      "title": "分類佔比\n",
      "chartLabelFormat": "{c}",
      "categoryProperty": "area",
      "valueProperty": "$file_count"
    },
