    {
      "id": "7c3516c3-c186-4dd5-bcc3-aad33dfd14b2",
      "type": "chart",
      "titleAlign": "center",
      "tabTitle": "項目分類\n",
      "maxWidthRatio": -1,
      "showBorder": true,
      "showTitle": true,
      "showShadow": false,
      "createAt": "2025-11-16T02:41:42.144Z",
      "updateAt": "2025-11-18T09:42:19.348Z",
      "chartType": "pie",
      "filter": {
        "id": "26a0fdff-dddc-48a0-89a3-7803dc46def8",
        "type": "group",
        "operator": "and",
        "conditions": [
          {
            "id": "731e7234-b676-4f37-8c93-796005dc9d7a",
            "type": "jsQuery",
            "operator": "contains",
            "property": "${file.tags}",
            "value": "// 取得目前頁面\nconst page = dv.current();\n\n// 判斷頁面類型\nconst isIndex = page.tags?.includes(\"類型/INDEX\");\nconst isMOC = page.tags?.includes(\"類型/MOC\");\nconst isProject = page.tags?.includes(\"類型/專案\");\n\n// INDEX → 找 MOC\nif (isIndex) {\n    dv.header(2, \"📘 所屬 MOC\");\n    dv.table([\"MOC\", \"路徑\"], \n        dv.pages(\"#類型/MOC\")\n          .where(p => p.parent && p.parent == page.file.name)\n          .map(p => [p.file.link, p.file.path])\n    );\n}\n\n// MOC → 找項目 / 專案\nif (isMOC) {\n    dv.header(2, \"📗 所屬項目 / 專案\");\n    dv.table([\"Project\", \"路徑\"], \n        dv.pages(\"#類型/專案\")\n          .where(p => p.moc && p.moc == page.file.name)\n          .map(p => [p.file.link, p.file.path])\n    );\n}\n\n// 項目 → 找任務\nif (isProject) {\n    dv.header(2, \"📒 任務列表\");\n    const tasks = dv.pages()\n        .file\n        .tasks\n        .where(t => t.path == page.file.path);\n    \n    dv.taskList(tasks, true);\n}\n",
            "conditions": []
          }
        ]
      },
      "labelFormat": "$none",
      "series": [
        {
          "id": "85300baf-33b8-4dba-8225-626079a12e48",
          "name": "$file_count",
          "precision": 2
        }
      ],
      "sortField": "xAxisValue",
      "sortOrder": "asc",
      "maxHeight": 300,
      "chartColorSet": "default",
