      "query": "const afterTomorrow = dv.luxon.DateTime.now().startOf(\"day\").plus({ days: 4 });\nlet allTasks = dv.pages().file.tasks\n  .where(t => !t.completed && t.due && t.due.hasSame(afterTomorrow, \"day\"));\n\ndv.header(2, ` ${afterTomorrow.toFormat(\"yyyy-MM-dd \")}`);\nif (allTasks.length > 0) {\n  dv.taskList(allTasks, false);\n} else {\n  dv.paragraph(\"✅ 無代辦\");\n}\n",
