) return;\n    const initialize = async () => {\n      isInitializedRef.current = true;\n      await loadTasks();\n    };\n    initialize();\n  }, [loadTasks]);\n\n  // 任务过滤和分组保持不变\n  const {\n    filteredTasks,\n    stats\n  } = useMemo(() => {\n    const filtered = tasks.filter(task => {\n      const taskDate = dateUtils.getDateFromNotePath(task.notePath);\n      const isFuture = dateUtils.isFutureDate(taskDate);\n      if (filter !== 'future' && isFuture) {\n        return false;\n      }\n      if (filter === 'future' && !isFuture) {\n        return false;\n      }\n      let statusMatch = true;\n      if (filter !== 'future') {\n        switch (filter) {\n          case 'active':\n            statusMatch = !task.completed;\n            break;\n          case 'completed':\n            statusMatch = task.completed;\n            break;\n          default:\n            statusMatch = true;\n        }\n      }\n      const searchMatch = !searchQuery || task.text.toLowerCase().includes(searchQuery.toLowerCase()) || task.tags?.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()));\n      return statusMatch && searchMatch;\n    }, [tasks, filter, searchQuery, dateUtils]);\n    const stats = {\n      total: tasks.filter(t => !dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length,\n      completed: tasks.filter(t => t.completed && !dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length,\n      active: tasks.filter(t => !t.completed && !dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length,\n      future: tasks.filter(t => dateUtils.isFutureDate(dateUtils.getDateFromNotePath(t.notePath))).length\n    };\n    return {\n      filteredTasks: filtered,\n      stats\n    };\n  }, [tasks, filter, searchQuery, dateUtils]);\n  const groupedTasks = useMemo(() => {\n    const groups = {};\n    filteredTasks.forEach(task => {\n      const date = dateUtils.getDateFromNotePath(task.notePath);\n      if (!groups[dat