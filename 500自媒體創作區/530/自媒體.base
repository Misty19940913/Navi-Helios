views:
  - type: table
    name: 表格
    filters:
      and:
        - file.tags.contains("系統/創作")
        - file.folder.containsAny("530")
    order:
      - file.name
      - time_create
      - time_modifie
      - time_publish
      - 分享
      - 按讚
      - 留言
      - 轉發
    sort:
      - property: time_create
        direction: ASC
