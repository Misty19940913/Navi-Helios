formulas:
  未命名: ""
views:
  - type: table
    name: 表格
    filters:
      and:
        - time_create == today()
    order:
      - file.basename
      - tags
      - status
    sort:
      - property: TQ_short_mode
        direction: DESC
      - property: TQ_explain
        direction: DESC
    columnSize:
      file.basename: 412
      note.tags: 467
  - type: list
    name: 视图
    order:
      - file.name
    indentProperties: true
