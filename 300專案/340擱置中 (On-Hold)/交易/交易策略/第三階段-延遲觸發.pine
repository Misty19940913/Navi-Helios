//@version=6
strategy("順勢布林 + KD 策略（單單版）", overlay=true)

// === 參數設定 ===
lengthBB = input.int(21, title="布林通道期數")
mult = input.float(2.1, title="布林通道倍率")
lengthK = input.int(9, title="KD K 長度")
smoothK = input.int(3, title="K 平滑")
smoothD = input.int(3, title="D 平滑")
slLookback = input.int(5, title="止損回看K棒數")

// === 計算布林通道 ===
basis = ta.sma(close, lengthBB)
dev = mult * ta.stdev(close, lengthBB)
upper = basis + dev
lower = basis - dev

// === 計算63均線 ===
ma63 = ta.sma(close, 63)

// === 繪製布林通道和均線 ===
plot(basis, color=color.gray, title="布林中軌")
plot(upper, color=color.red, title="布林上軌(2.1)")
plot(lower, color=color.green, title="布林下軌(2.1)")
plot(ma63, color=color.yellow, title="63均線", linewidth=2)

// === 計算KD ===
k = ta.sma(ta.stoch(close, high, low, lengthK), smoothK)
d = ta.sma(k, smoothD)
plot(k, title="K", color=color.orange)
plot(d, title="D", color=color.blue)

// === 觸碰記錄變數 ===
var bool touchedUpper = false
var bool touchedLower = false
var int barsSinceUpperTouch = 0
var int barsSinceLowerTouch = 0

// === 檢測觸碰2.1倍布林帶 ===
// 檢測是否觸碰上軌（最高價觸碰上軌）
if (high >= upper)
    touchedUpper := true
    barsSinceUpperTouch := 0

// 檢測是否觸碰下軌（最低價觸碰下軌）
if (low <= lower)
    touchedLower := true
    barsSinceLowerTouch := 0

// === 更新觸碰後的K棒計數 ===
if (touchedUpper)
    barsSinceUpperTouch := barsSinceUpperTouch + 1

if (touchedLower)
    barsSinceLowerTouch := barsSinceLowerTouch + 1

// === 多單進場條件 ===
// 曾經觸碰2.1倍下軌，且KD在20以下出現金叉
longCondition = touchedLower and k <= 20 and d <= 20 and ta.crossover(k, d)
if (longCondition)
    entry_price = close
    long_stop = ta.lowest(low, slLookback)
    
    // 停利：布林下軌到63均線的80%位置
    long_take = lower + (ma63 - lower) * 0.8
    
    // 下單
    strategy.entry("多單進場", strategy.long)
    strategy.exit("多單出場", from_entry="多單進場", stop=long_stop, limit=long_take)
    
    touchedLower := false  // 重置觸碰狀態
    barsSinceLowerTouch := 0
    
    // 顯示進場資訊
    label.new(bar_index, low, "多單進場\n進場: " + str.tostring(entry_price) + "\n停損: " + str.tostring(long_stop) + "\n停利: " + str.tostring(long_take), 
              color=color.blue, style=label.style_label_up, textcolor=color.white)

// === 空單進場條件 ===
// 曾經觸碰2.1倍上軌，且KD在80以上出現死叉
shortCondition = touchedUpper and k >= 80 and d >= 80 and ta.crossunder(k, d)
if (shortCondition)
    entry_price = close
    short_stop = ta.highest(high, slLookback)
    
    // 停利：布林上軌到63均線的80%位置
    short_take = upper - (upper - ma63) * 0.8
    
    // 下單
    strategy.entry("空單進場", strategy.short)
    strategy.exit("空單出場", from_entry="空單進場", stop=short_stop, limit=short_take)
    
    touchedUpper := false  // 重置觸碰狀態
    barsSinceUpperTouch := 0
    
    // 顯示進場資訊
    label.new(bar_index, high, "空單進場\n進場: " + str.tostring(entry_price) + "\n停損: " + str.tostring(short_stop) + "\n停利: " + str.tostring(short_take), 
              color=color.purple, style=label.style_label_down, textcolor=color.white)

// === 觸碰失效條件 ===
// 如果觸碰後超過50根K棒仍未進場，則重置觸碰狀態
if (barsSinceUpperTouch > 50)
    touchedUpper := false
    barsSinceUpperTouch := 0

if (barsSinceLowerTouch > 50)
    touchedLower := false
    barsSinceLowerTouch := 0

// === 視覺化觸碰狀態 ===
bgcolor(touchedUpper ? color.new(color.red, 90) : na, title="觸碰上軌")
bgcolor(touchedLower ? color.new(color.green, 90) : na, title="觸碰下軌")

// === 顯示觸碰資訊 ===
if (touchedUpper)
    label.new(bar_index, high, "已觸碰上軌\n等待KD死叉", 
              color=color.red, style=label.style_label_down, textcolor=color.white, size=size.small)

if (touchedLower)
    label.new(bar_index, low, "已觸碰下軌\n等待KD金叉", 
              color=color.green, style=label.style_label_up, textcolor=color.white, size=size.small) 