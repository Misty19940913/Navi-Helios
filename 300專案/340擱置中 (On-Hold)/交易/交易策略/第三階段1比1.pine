//@version=6
strategy("順勢布林 + KD 策略（正確版）", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=1)

// === 參數設定 ===
lengthBB = input.int(21, title="布林通道期數")
mult = input.float(2.1, title="布林通道倍率")
lengthK = input.int(9, title="KD K 長度")
smoothK = input.int(3, title="K 平滑")
smoothD = input.int(3, title="D 平滑")
slLookback = input.int(5, title="止損回看K棒數")

// === 風險管理參數 ===
riskPercent = input.float(1.0, title="風險百分比", minval=0.1, maxval=10.0, step=0.1)

// === 獲利倍率管理參數 ===
profitMultiplier = input.float(1.5, title="獲利倍率", minval=0.5, maxval=5.0, step=0.1, tooltip="停利距離 = 停損距離 × 獲利倍率")

// === 計算布林通道 ===
basis = ta.sma(close, lengthBB)
dev = mult * ta.stdev(close, lengthBB)
upper = basis + dev
lower = basis - dev

plot(basis, color=color.gray, title="布林中軌")
plot(upper, color=color.red, title="布林上軌")
plot(lower, color=color.green, title="布林下軌")

// === 計算KD ===
k = ta.sma(ta.stoch(close, high, low, lengthK), smoothK)
d = ta.sma(k, smoothD)
plot(k, title="K", color=color.orange)
plot(d, title="D", color=color.blue)

// === 計算倉位大小函數 ===
calculatePositionSize(entryPrice, stopPrice) =>
    riskAmount = strategy.equity * riskPercent / 100
    stopDistance = math.abs(entryPrice - stopPrice)
    positionSize = riskAmount / stopDistance
    positionSize

// === 多單條件 ===
longCondition = ta.crossover(k, d) and close <= lower and close < basis
if (longCondition)
    entry_price = close
    long_stop = ta.lowest(low, slLookback)
    long_take = entry_price + (entry_price - long_stop) * profitMultiplier  // 可調整獲利倍率
    
    // 計算倉位大小
    long_qty = calculatePositionSize(entry_price, long_stop)
    
    strategy.entry("多單進場", strategy.long, qty=long_qty)
    strategy.exit("多單出場", from_entry="多單進場", stop=long_stop, limit=long_take)

// === 空單條件 ===
shortCondition = ta.crossunder(k, d) and close >= upper and close > basis
if (shortCondition)
    entry_price = close
    short_stop = ta.highest(high, slLookback)
    short_take = entry_price - (short_stop - entry_price) * profitMultiplier  // 可調整獲利倍率
    
    // 計算倉位大小
    short_qty = calculatePositionSize(entry_price, short_stop)
    
    strategy.entry("空單進場", strategy.short, qty=short_qty)
    strategy.exit("空單出場", from_entry="空單進場", stop=short_stop, limit=short_take)