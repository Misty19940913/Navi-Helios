		{"id":"e_balance_transcendence","fromNode":"node_dyn_balance","fromSide":"bottom","toNode":"node_transcendence","toSide":"top","label":"系統穩定後，追求更高意義"},
		{"id":"e_mindset_efficiency","fromNode":"node_hunter_mindset","fromSide":"right","toNode":"node_efficiency_priority","toSide":"left","label":"主權經營的具體實踐"},
		{"id":"e_priority_rev","toFloating":false,"fromFloating":false,"fromNode":"node_efficiency_priority","fromSide":"top","toNode":"node_efficiency_rev","toSide":"left","label":"戰略轉化為行動"},
		{"id":"e_dist_efficiency","toFloating":false,"fromFloating":false,"fromNode":"node_dist_sovereignty","fromSide":"top","toNode":"node_efficiency_priority","toSide":"right","label":"技術槓桿降低工時"},
