		{"id":"e_skill_stack_monopoly","toFloating":false,"fromFloating":false,"fromNode":"node_skill_stack","fromSide":"right","toNode":"node_personal_monopoly","toSide":"bottom","label":"實現壟斷的技術路徑"},
